# Function to check if array is sorted
def is_sorted(arr):
    n = len(arr)
    
    for i in range(n - 1):
        if arr[i] > arr[i + 1]:
            return False
    return True


# Taking input from user
arr = list(map(int, input("Enter array elements separated by space: ").split()))

# Checking
if is_sorted(arr):
    print("Array is sorted")
else:
    print("Array is not sorted")
